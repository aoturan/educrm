# Production environment variables for EduCRM API
# Copy to .env.prod and fill with real values. .env.prod is git-ignored.
# .NET maps "__" to JSON nesting (ConnectionStrings__Default -> ConnectionStrings:Default).

# --- Database ---
ConnectionStrings__Default=Host=educrm-prod-postgres-do-user-2726277-0.i.db.ondigitalocean.com;Port=25060;Database=educrm;Username=educrm_app;Password=REPLACE_ME;SslMode=Require

# --- Auth ---
Auth__Jwt__SigningKey=REPLACE_ME

# --- DigitalOcean Spaces ---
DigitalOceanSpaces__AccessKeyId=REPLACE_ME
DigitalOceanSpaces__SecretKey=REPLACE_ME

# --- Email (Resend) ---
Email__Resend__ApiKey=REPLACE_ME

# --- Cloudflare Turnstile ---
Turnstile__SecretKey=REPLACE_ME
