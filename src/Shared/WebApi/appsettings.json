{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Auth": {
    "Jwt": {
      "Authority": "",
      "Audience": "educrm-api",
      "Issuer": "educrm",
      "ExpirationMinutes": 480
    }
  },
  "PlanLimits": {
    "Free": { "Users": 1, "ActivePersons": 150,  "ActivePrograms": 10,   "OpenFollowUps": 50,   "ExportEnabled": false },
    "Plus": { "Users": 3, "ActivePersons": 1000, "ActivePrograms": null, "OpenFollowUps": 500,  "ExportEnabled": true  },
    "Pro":  { "Users": 5, "ActivePersons": 5000, "ActivePrograms": null, "OpenFollowUps": null, "ExportEnabled": true  }
  },
  "PlanPricing": {
    "Free": 0,
    "Plus": 2900,
    "Pro":  5900
  },
  "BankAccounts": [
    {
      "bankName": "X Bankası",
      "accountHolder": "EduCRM Teknoloji Ltd. Şti.",
      "iban": "TR00 0000 0000 0000 0000 0000 00",
      "note": "Ödeme açıklamasına referans kodunu yazın."
    }
  ],
  "Email": {
    "Provider": "Resend",
    "FromEmail": "noreply@educrm.app",
    "FromName": "EduCRM"
  },
  "Account": {
    "PasswordReset": {
      "RequestCooldownSeconds": 60,
      "TokenLifetimeMinutes": 30
    },
    "EmailVerification": {
      "RequestCooldownSeconds": 180,
      "TokenLifetimeMinutes": 1440
    }
  },
  "RateLimits": {
    "Rules": [
      { "Action": "auth.login.ip",    "Limit": 20, "WindowSeconds": 600 },
      { "Action": "auth.login.email", "Limit": 10, "WindowSeconds": 600 },

      { "Action": "auth.register.ip",    "Limit": 5, "WindowSeconds": 3600 },
      { "Action": "auth.register.email", "Limit": 2, "WindowSeconds": 3600 },

      { "Action": "auth.forgot_password.ip",    "Limit": 10, "WindowSeconds": 3600 },
      { "Action": "auth.forgot_password.email", "Limit": 3,  "WindowSeconds": 3600 },
      
      { "Action": "auth.resend_verification.ip",    "Limit": 10, "WindowSeconds": 3600 },
      { "Action": "auth.resend_verification.email", "Limit": 3,  "WindowSeconds": 3600 },

      { "Action": "auth.reset_password.ip",    "Limit": 20, "WindowSeconds": 3600 },
      { "Action": "auth.reset_password.email", "Limit": 10, "WindowSeconds": 3600 },

      { "Action": "auth.verify_email.ip",    "Limit": 30, "WindowSeconds": 3600 },
      { "Action": "auth.verify_email.email", "Limit": 10, "WindowSeconds": 3600 },

      { "Action": "public.contact.ip",     "Limit": 5, "WindowSeconds": 600 },
      { "Action": "public.application.ip", "Limit": 5, "WindowSeconds": 600 },

      { "Action": "account.export.org", "Limit": 10, "WindowSeconds": 3600 }
    ]
  }
}
